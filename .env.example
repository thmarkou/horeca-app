# Copy to `.env`:  cp .env.example .env
# Optional overrides:  cp .env.horecaapp.example .env.horecaapp
# Loader: scripts/load-env.mjs
#
# Local platform DB is SQLite. After clone:  pnpm db:setup  (or db:push + db:seed)
# Default file: data/horeca.db
# SQLITE_PATH=./data/horeca.db
#
# Platform API (Hono) uses PLATFORM_JWT_SECRET for signing sessions.
PLATFORM_JWT_SECRET=change-me-in-development-only-use-long-random-string
# Listen port: PLATFORM_PORT overrides PORT; default 3000.
# The Expo app must use the same port: set EXPO_PUBLIC_DEV_API_PORT and/or EXPO_PUBLIC_API_BASE_URL in `.env.horecaapp`.
# Bind: default 0.0.0.0 so a physical iPhone on Wi-Fi can reach the API. To listen only on this Mac: PLATFORM_BIND_HOST=127.0.0.1
# PORT=3000
# PLATFORM_PORT=3000
# PLATFORM_BIND_HOST=0.0.0.0
#
# Physical iPhone (same Wi-Fi as Mac). Pick one:
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.1.10
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000
#
# If `pnpm dev` says a port is busy: quit other Metro/API terminals, or `lsof -i :8081 -i :3000` and stop those PIDs.
#
# Price-alert digest emails (Resend REST — optional; without key, only in-app + push fire)
# HORECA_RESEND_API_KEY=re_xxxxxxxx
# HORECA_EMAIL_FROM=Horeca Source <onboarding@resend.dev>
