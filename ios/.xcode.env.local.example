# Copy this file to `.xcode.env.local` in the same folder (ios/).
# `.xcode.env.local` is gitignored — put your Mac's Wi‑Fi IP and the platform port here.
#
# Physical iPhone + Xcode: without this, embedded/prebundled JS may use 127.0.0.1:3010;
# the app rewrites the host to your LAN IP but the port must match `pnpm dev` platform (usually 3010).
#
# Example (replace with your Mac's IP from System Settings → Network):
export EXPO_PUBLIC_API_BASE_URL=http://192.168.100.40:3010
