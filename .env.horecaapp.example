# Copy to `.env.horecaapp` in the project root.
# Do not commit `.env` or `.env.horecaapp`.

# Optional: path to SQLite file (relative to project root or absolute). Default: data/horeca.db
# SQLITE_PATH=./data/horeca.db

# Same secret as root `.env` — used by platform auth (see PLATFORM_JWT_SECRET).
PLATFORM_JWT_SECRET=change-me-in-development-only-use-long-random-string

PORT=3000
EXPO_PORT=8081
# Match PORT above when not using a full base URL:
# EXPO_PUBLIC_DEV_API_PORT=3000

VITE_APP_ID=horeca-local-dev
EXPO_PUBLIC_APP_ID=horeca-local-dev

# Simulator: optional. Physical iPhone: do NOT use 127.0.0.1 (that is the phone, not your Mac).
# Either omit EXPO_PUBLIC_API_BASE_URL (app uses your Mac IP from Metro) or set:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XX:3000
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.1.XX
#
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# OAUTH_SERVER_URL=
# EXPO_PUBLIC_OAUTH_SERVER_URL=
